```
# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables
.env
.env.local
.env.*

# Build outputs
backend/dist/
frontend/dist/
backend/build/
frontend/build/
target/

# Python cache (if any Python files exist in backend)
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd

# Logs
*.log
logs/

# OS generated files
.DS_Store
Thumbs.db

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp

# Local configuration
config/local.*
```